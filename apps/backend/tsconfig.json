{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2020",
        "rootDir": "./src",
        "outDir": "./dist",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true
    }
}
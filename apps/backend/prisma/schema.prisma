generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CLIENT)

  uploadedDocuments Document[] @relation("UploadedDocuments")
  chatSessions      ChatSession[]
  usages            Usage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  type      String
  source    String
  status    String   @default("PENDING")

  url           String?
  sizeBytes     Int?
  chunks        Int      @default(0)
  ragDocumentId String?

  // ✅ NUEVO: guarda el texto ya extraído (de PDF, DOCX, URL, texto manual, etc.)
  // Sin esto no hay forma de reindexar un documento sin volver a subir el archivo original.
  extractedText String?

  uploadedById String?
  uploadedBy   User? @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([source])
  @@index([ragDocumentId])
}

model ChatSession {
  id        String   @id @default(uuid())
  title     String

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  messages  Message[]
  usages    Usage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // 🔥 performance
}

model Message {
  id        String      @id @default(uuid())
  role      String
  content   String

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([sessionId]) // 🔥 performance
}

model Usage {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  sessionId String?
  session   ChatSession? @relation(fields: [sessionId], references: [id])

  model     String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?

  latencyMs Int? // 🔥 NUEVO (clave para métricas)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt]) // 🔥 para gráficos por fecha
}
